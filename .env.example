# clawdparty environment template.
#
# Copy nothing by hand: run `bin/setup`, which generates SIDECAR_SHARED_SECRET
# into the git-ignored `.env.local` (the file Compose actually loads). This file
# documents every slot and its default. Values here are SAFE DEFAULTS — no
# secrets. The real secret lives only in `.env.local`.

# --- Sidecar shared secret -------------------------------------------------
# Bearer secret shared by `rails` and `sidecar` for POST /internal/events and
# the heartbeat. Generated by `bin/setup` into `.env.local`; both services read
# the SAME value from that single source. Leave blank here.
SIDECAR_SHARED_SECRET=

# --- Service addressing (compose DNS; no fixed host hard-coded) ------------
# rails -> sidecar direction.
SIDECAR_URL=http://sidecar:8787
# sidecar -> rails callback direction (POST /internal/events + heartbeat).
# DISTINCT from SIDECAR_URL — do not conflate the two directions.
RAILS_INTERNAL_URL=http://rails:3000

# --- Target repository -----------------------------------------------------
# ABSOLUTE host path to the directory Claude works in — set it to the PARENT of
# your repos so the folder picker can browse across them (e.g. /Users/you/dev).
# Mounted READ-WRITE into `rails` + `sidecar` at the IDENTICAL in-container path
# (host path == container path), and the container's REPO_ROOT is derived from
# it. Identical paths are load-bearing: git worktree metadata stores ABSOLUTE
# paths, so a worktree created in the container is only valid on the host (and in
# GitHub Desktop / host `git worktree`) when the two paths match. Must be
# absolute (a relative path cannot be an identical mount target).
TARGET_REPO_PATH=/repo

# --- PostgreSQL ------------------------------------------------------------
# Trust auth on the private compose network (the trusted-LAN perimeter is the
# security boundary). No password under trust auth.
POSTGRES_HOST_AUTH_METHOD=trust
POSTGRES_USER=postgres
POSTGRES_DB=postgres
# rails/jobs connection coordinates pointing at the `postgres` service.
DATABASE_HOST=postgres
DATABASE_USER=postgres

# --- Environment selectors -------------------------------------------------
RAILS_ENV=development
NODE_ENV=development

# --- Vite (dev) ------------------------------------------------------------
# Polling so HMR detects host edits over the macOS :delegated bind mount.
VITE_USE_POLLING=true

# --- Claude / AWS auth passthrough (only-when-set) -------------------------
# The sidecar inherits the HOST developer's EXISTING login — API key,
# subscription/enterprise OAuth, or Bedrock. The app owns NO credential. These
# are passed through ONLY when set on the host (so unset stays unset and the
# SDK's own auto-detection/precedence is preserved). Leave blank/omit unless
# your host already exports them.
#   ANTHROPIC_API_KEY=
#   ANTHROPIC_AUTH_TOKEN=
#   CLAUDE_CODE_OAUTH_TOKEN=        # macOS Keychain OAuth: run `claude setup-token` then export this
#   CLAUDE_CODE_USE_BEDROCK=
#   CLAUDE_CODE_USE_VERTEX=
#   AWS_PROFILE=
#   AWS_REGION=
#
# ANTHROPIC_MODEL is NOT a host passthrough — set it in .env.local so the SAME
# value is authoritative for BOTH rails (run payload) and the sidecar (SDK). On
# Bedrock use the inference-profile form, e.g.:
#   ANTHROPIC_MODEL=us.anthropic.claude-opus-4-8[1m]
