#!/usr/bin/env bash
# bin/start — the single entry point for the clawdparty dev stack.
#
# Builds the images then brings the whole stack up. Build-before-up so a fresh
# machine (no images yet) does not fail the `up` step on a missing image.
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${repo_root}"

if [[ ! -f ".env.local" ]]; then
  echo "No .env.local found — run bin/setup first (generates SIDECAR_SHARED_SECRET)." >&2
  exit 1
fi

# --env-file .env.local so a single file drives BOTH ${...} substitution in the
# compose file (e.g. the TARGET_REPO_PATH bind-mount source) AND the in-container
# env (via each service's `env_file: .env.local`). Without this, compose reads
# only the default `.env` for substitution, so TARGET_REPO_PATH set in .env.local
# is silently ignored for the mount.
docker compose --env-file .env.local build
exec docker compose --env-file .env.local up --remove-orphans
