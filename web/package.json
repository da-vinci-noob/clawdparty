{
  "name": "@clawdparty/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "clawdparty SPA — React 19 + Vite + TypeScript + Tailwind v4. W1 scaffold: static shell, no data/cable wiring.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@clawdparty/contracts": "file:../packages/contracts",
    "@dnd-kit/core": "^6.3.1",
    "@rails/actioncable": "^8.0.0",
    "@tanstack/react-query": "^5.101.0",
    "anser": "^2.3.2",
    "react": "^19.2.0",
    "react-arborist": "^3.4.3",
    "react-diff-view": "^3.3.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^7.18.0",
    "shiki": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/rails__actioncable": "^6.1.11",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^25.0.0",
    "msw": "^2.14.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
