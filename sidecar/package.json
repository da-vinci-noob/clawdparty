{
  "name": "@clawdparty/sidecar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Node + Fastify sidecar wrapping @anthropic-ai/claude-agent-sdk. The only code that knows the SDK exists. Normalizes SDK messages into Contract-1 envelopes and POSTs them to Rails.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.195",
    "@clawdparty/contracts": "file:../packages/contracts",
    "fastify": "^5.9.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
